# 博闻访谈收集器 — 环境变量示例
# 复制为 .env 并填写实际值

# LLM 配置 (复用博闻项目的多模态 LLM 配置)
BOWEN_VLM_API_KEY=your-api-key
BOWEN_VLM_BASE_URL=https://api.openai.com/v1
BOWEN_VLM_MODEL=gpt-4o

# FunASR 转写服务 (复用项目已有服务)
FUNASR_SERVICE_URL=http://localhost:8765

# 向量服务 (复用项目已有服务)
VECTOR_STORE_URL=http://localhost:8766

# 知识库根目录
KNOWLEDGE_DIR=../knowledge

# 原始数据存储目录
STORAGE_DIR=../storage/interview-collector
